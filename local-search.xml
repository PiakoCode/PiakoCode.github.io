    <content type="html"><![CDATA[<h1 id="2022河南萌新联赛第（二）场-未完成"><a href="#2022河南萌新联赛第（二）场-未完成" class="headerlink" title="2022河南萌新联赛第（二）场(未完成)"></a>2022河南萌新联赛第（二）场(未完成)</h1><h2 id="A-妙手"><a href="#A-妙手" class="headerlink" title="A.  妙手"></a>A. <a href="https://ac.nowcoder.com/acm/contest/37344/A"> 妙手</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-c++" data-language="c++"><code class="language-c++">#include &lt;iostream&gt;#include &lt;algorithm&gt; using namespace std; int main() &#123;    int a, b;    cin &gt;&gt; a &gt;&gt; b;    if (a &#x3D;&#x3D; b) puts(&quot;No&quot;);    else puts(__gcd(a, b) &#x3D;&#x3D; 1 ? &quot;Yes&quot; : &quot;No&quot;);    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure><h2 id="B-宝石"><a href="#B-宝石" class="headerlink" title="B.  宝石"></a>B. <a href="https://ac.nowcoder.com/acm/contest/37344/B"> 宝石</a></h2><h2 id="C-斩龙"><a href="#C-斩龙" class="headerlink" title="C.  斩龙"></a>C. <a href="https://ac.nowcoder.com/acm/contest/37344/C"> 斩龙</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-c++" data-language="c++"><code class="language-c++">#include&lt;iostream&gt;#include&lt;algorithm&gt;#include&lt;string&gt;#include&lt;cstring&gt;#include&lt;vector&gt;#include&lt;queue&gt;#include&lt;map&gt;#include&lt;cmath&gt;using namespace std;#define LL long long#define x first#define y secondconst LL N&#x3D;1000010;const LL K&#x3D;1010;typedef pair&lt;LL,LL&gt; PII;int main()&#123;    LL a1, h1;    LL a2, h2, x;    LL k;    LL a3,h3;    cin &gt;&gt; a1 &gt;&gt; h1;    cin &gt;&gt; a2 &gt;&gt; h2&gt;&gt;x;    cin &gt;&gt; k;    cin &gt;&gt; a3 &gt;&gt; h3;    LL n1;    n1 &#x3D; h2 &#x2F; a1;    if(h2%a1!&#x3D;0)        n1++;    LL d &#x3D; h2 &#x2F; a1 * a2;    LL s1&#x3D;d*x;    LL n2;    n2 &#x3D; h3 &#x2F; a1;    if(h3%a1!&#x3D;0)        n2++;    LL s3 &#x3D; h3 &#x2F; a1 * a3;    LL s2 &#x3D; n1 * k * a3;    if(h1&gt;&#x3D;s1+s2+s3)    &#123;        cout &lt;&lt; n1 * x + n2;    &#125;    else cout &lt;&lt; &quot;No Franxx!&quot;;    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure><h2 id="D-数对"><a href="#D-数对" class="headerlink" title="D.  数对"></a>D. <a href="https://ac.nowcoder.com/acm/contest/37344/D"> 数对</a></h2><h2 id="E-双星"><a href="#E-双星" class="headerlink" title="E. 双星"></a>E. <a href="https://ac.nowcoder.com/acm/contest/37344/E">双星</a></h2><h2 id="F-手办"><a href="#F-手办" class="headerlink" title="F. 手办"></a>F. <a href="https://ac.nowcoder.com/acm/contest/37344/F">手办</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-none"><code class="language-none">#include &lt;iostream&gt;#include &lt;algorithm&gt;#include &lt;string&gt;#include &lt;cstring&gt;#include &lt;vector&gt;#include &lt;queue&gt;#include &lt;map&gt;#include &lt;cmath&gt;#include&lt;set&gt;using namespace std;#define LL long long#define x first#define y secondconst int N &#x3D; 1000010;const int K &#x3D; 1010;typedef pair&lt;int, int&gt; PII;int a[K];int main()&#123;    int t;    cin &gt;&gt; t;    for (int i &#x3D; 1; i &lt;&#x3D; 1000; i++)    &#123;        a[i]&#x3D;i*i*i;    &#125;    while (t--)    &#123;        LL n;        cin &gt;&gt; n;        LL temp&#x3D;upper_bound(a+1,a+1+1000,n)-a;        temp--;        LL res &#x3D; 0;        for (LL i &#x3D; 1; i &lt;&#x3D; temp;i++)        &#123;            if(n%(i*i*i)&#x3D;&#x3D;0)                res++;        &#125;        cout &lt;&lt; res &lt;&lt; endl;    &#125;    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure><h2 id="G-无限"><a href="#G-无限" class="headerlink" title="G.  无限"></a>G. <a href="https://ac.nowcoder.com/acm/contest/37344/G"> 无限</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-none"><code class="language-none">#include&lt;bits&#x2F;stdc++.h&gt;#define LL long long#define x first#define y secondusing namespace std;const int N&#x3D;1000010;const int K&#x3D;1010;typedef pair&lt;int,int&gt; PII;int f[N];int main()&#123;    int p;    cin &gt;&gt; p;    f[1]&#x3D;1;    f[2]&#x3D;1;    for (int i &#x3D; 3; i &lt;&#x3D; p;i++)    &#123;        f[i] &#x3D; (f[i - 1] + f[i - 2]) % 998244353;    &#125;            LL res&#x3D;0;    for(int i&#x3D;1;i&lt;&#x3D;p;i++)    &#123;        res&#x3D;(res+f[i])%998244353;    &#125;    cout&lt;&lt;res;    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure><h2 id="H-0和1"><a href="#H-0和1" class="headerlink" title="H. 0和1"></a>H. <a href="https://ac.nowcoder.com/acm/contest/37344/H">0和1</a></h2><h2 id="I-22数"><a href="#I-22数" class="headerlink" title="I.  22数"></a>I. <a href="https://ac.nowcoder.com/acm/contest/37344/I"> 22数</a></h2><h2 id="J-签到"><a href="#J-签到" class="headerlink" title="J.  签到"></a>J. <a href="https://ac.nowcoder.com/acm/contest/37344/J"> 签到</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-c++" data-language="c++"><code class="language-c++">#include &lt;iostream&gt;#include &lt;algorithm&gt;#include &lt;string&gt;#include &lt;cstring&gt;#include &lt;vector&gt;#include &lt;queue&gt;#include &lt;map&gt;#include &lt;cmath&gt;using namespace std;#define LL long long#define x first#define y secondconst int N &#x3D; 1000010;const int K &#x3D; 1010;typedef pair&lt;int, int&gt; PII;LL a[K];LL b[K];LL c[K];map&lt;LL, LL&gt; m;int main()&#123;    int n;    cin &gt;&gt; n;    LL sum &#x3D; 0;    for (int i &#x3D; 0; i &lt; n; i++)    &#123;        scanf(&quot;%lld&quot;, &amp;a[i]);    &#125;    sort(a, a + n);    int flag &#x3D; 0;    for (int i &#x3D; 0; i &lt; n; i++)    &#123;        for (int j &#x3D; 0; j &lt; n; j++)        &#123;            m[a[i] + a[j]] &#x3D; 1;        &#125;    &#125;    for (int i &#x3D; 0; i &lt; n; i++)    &#123;        for (int j &#x3D; 0; j &lt; n; j++)        &#123;            if (m[a[i] - a[j]] &#x3D;&#x3D; 1)            &#123;                flag &#x3D; 1;                break;            &#125;        &#125;        if (flag &#x3D;&#x3D; 1)            break;    &#125;    if (flag &#x3D;&#x3D; 0)        cout &lt;&lt; &quot;No&quot; &lt;&lt; endl;    else        cout &lt;&lt; &quot;Yes&quot; &lt;&lt; endl;    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure><h2 id="K-大米"><a href="#K-大米" class="headerlink" title="K.  大米"></a>K. <a href="https://ac.nowcoder.com/acm/contest/37344/K"> 大米</a></h2><h2 id="L-HPU"><a href="#L-HPU" class="headerlink" title="L.  HPU"></a>L. <a href="https://ac.nowcoder.com/acm/contest/37344/L"> HPU</a></h2><figure><div class="code-wrapper"><pre class="line-numbers language-c++" data-language="c++"><code class="language-c++">#include&lt;iostream&gt;#include&lt;algorithm&gt;#include&lt;string&gt;#include&lt;cstring&gt;#include&lt;vector&gt;#include&lt;queue&gt;#include&lt;map&gt;#include&lt;cmath&gt;using namespace std;#define LL long long#define x first#define y secondconst int N&#x3D;1000010;const int K&#x3D;1010;typedef pair&lt;int,int&gt; PII;int main()&#123;        string s;    cin &gt;&gt; s;    string a &#x3D; &quot;HPU&quot;;    int res &#x3D; 0;    int p &#x3D; 0;    int len&#x3D;s.length();    while (p &#x3D; s.find(a, p),p&lt;len&amp;&amp;p&gt;&#x3D;0)    &#123;        p++;        res++;    &#125;    cout&lt;&lt;res&lt;&lt;endl;        return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre></div></figure>]]></content>
    
    
    
